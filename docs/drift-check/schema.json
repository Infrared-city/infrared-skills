{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DriftCheckResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "actions"],
  "properties": {
    "status": {
      "enum": ["in_sync", "actions_required"],
      "description": "Top-level verdict for this run."
    },
    "summary": {
      "type": "string",
      "description": "One sentence: count of findings by severity, count already tracked.",
      "maxLength": 240
    },
    "actions": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/NewIssue" },
          { "$ref": "#/definitions/UpdateIssue" },
          { "$ref": "#/definitions/NewPR" },
          { "$ref": "#/definitions/UpdatePR" },
          { "$ref": "#/definitions/NoAction" }
        ]
      }
    }
  },
  "definitions": {
    "Severity": { "enum": ["critical", "important", "minor"] },

    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sdk_file", "skill_file"],
      "properties": {
        "sdk_file": {
          "type": "string",
          "description": "Path in infrared-api-sdk that proves the drift, with optional :line."
        },
        "skill_file": {
          "type": "string",
          "description": "Path in infrared-skills that is wrong / outdated."
        },
        "quoted_skill_text": {
          "type": "string",
          "description": "The exact line / phrase from the skill file that needs to change.",
          "maxLength": 500
        },
        "quoted_sdk_text": {
          "type": "string",
          "description": "The line / phrase from the SDK that contradicts it.",
          "maxLength": 500
        }
      }
    },

    "NewIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "fingerprint", "severity", "title", "body", "labels", "evidence"],
      "properties": {
        "type":     { "const": "new_issue" },
        "fingerprint": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Stable kebab-case dedup key, e.g. skill-quickstart-enum-case."
        },
        "severity": { "$ref": "#/definitions/Severity" },
        "title":    { "type": "string", "maxLength": 100 },
        "body":     { "type": "string" },
        "labels":   { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "evidence": { "$ref": "#/definitions/Evidence" }
      }
    },

    "UpdateIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "fingerprint", "issue_number", "comment"],
      "properties": {
        "type":         { "const": "update_issue" },
        "fingerprint":  { "type": "string" },
        "issue_number": { "type": "integer", "minimum": 1 },
        "comment":      { "type": "string" },
        "close":        { "type": "boolean", "default": false },
        "evidence":     { "$ref": "#/definitions/Evidence" }
      }
    },

    "NewPR": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "fingerprint", "title", "body", "branch", "files"],
      "properties": {
        "type":        { "const": "new_pr" },
        "fingerprint": { "type": "string" },
        "title":       { "type": "string", "maxLength": 100 },
        "body":        { "type": "string" },
        "branch":      {
          "type": "string",
          "pattern": "^drift-fix/[a-z0-9-]+$",
          "description": "Branch name; must start with drift-fix/ for filterability."
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "old_string", "new_string"],
            "properties": {
              "path":       { "type": "string" },
              "old_string": { "type": "string" },
              "new_string": { "type": "string" }
            }
          }
        }
      }
    },

    "UpdatePR": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "fingerprint", "pr_number", "comment"],
      "properties": {
        "type":        { "const": "update_pr" },
        "fingerprint": { "type": "string" },
        "pr_number":   { "type": "integer", "minimum": 1 },
        "comment":     { "type": "string" },
        "request_review": { "type": "boolean", "default": false }
      }
    },

    "NoAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reason"],
      "properties": {
        "type":   { "const": "no_action" },
        "reason": { "type": "string", "maxLength": 500 },
        "fingerprint_observed": {
          "type": "string",
          "description": "Optional — fingerprint of the existing tracked item this no-op refers to."
        }
      }
    }
  }
}
