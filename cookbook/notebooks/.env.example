# Copy this file to `.env` (in this same directory) and fill in your key.
# The notebooks call `python-dotenv` to load these into the environment.

# Required: your Infrared API key.
INFRARED_API_KEY=your-api-key-here

# Optional: override the default base URL.
# Defaults to https://api.infrared.city when unset.
# INFRARED_BASE_URL=https://api.infrared.city
