# Infrared API credentials
# Obtain from https://app.infrared.city or your account dashboard
INFRARED_API_KEY=your-api-key-here

# Webhook secret for verifying incoming webhook signatures
# Generate one or obtain from your Infrared dashboard
WEBHOOK_SECRET=your-webhook-secret-here

# Public URL where the webhook server is reachable
# For local development with ngrok: https://<subdomain>.ngrok.io/webhook
WEBHOOK_URL=https://your-public-url.example.com/webhook

# SQLite database path (optional, defaults to demo.db in this directory)
# DB_PATH=/path/to/custom/demo.db

# Flask server port (optional, defaults to 8000)
# PORT=8000
